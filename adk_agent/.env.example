# Free Gemini API key — no billing needed
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_key_here

# Model — gemini-3.1-flash-lite-preview gives the best free-tier limits:
#   15 RPM, 500 RPD (enough for ~165 pipeline runs/day)
# Fallback options if this model is unavailable:
#   gemini-2.5-flash       → 5 RPM, 20 RPD  (higher quality, lower limits)
#   gemini-3-flash-preview → 5 RPM, 20 RPD  (high quality, low limits)
GEMINI_MODEL=gemini-3.1-flash-lite-preview
